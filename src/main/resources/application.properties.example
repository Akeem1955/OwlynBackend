spring.application.name=OwlynBackend

spring.servlet.multipart.max-file-size=7MB
spring.servlet.multipart.max-request-size=8MB

# Logging
logging.level.com.owlynbackend=DEBUG
logging.level.org.springframework=INFO
spring.docker.compose.enabled=true

# JPA
spring.jpa.hibernate.ddl-auto=create-drop

# API
api.base=/api/v1

# JWT
jwt.secret=YOUR_JWT_SECRET_BASE64
jwt.issuer=OwlynBackend

# Email (Gmail SMTP)
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.starttls.enable=true
spring.mail.port=587
spring.mail.host=smtp.gmail.com
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.username=YOUR_GMAIL_ADDRESS
spring.mail.password=YOUR_GMAIL_APP_PASSWORD

# Gemini API
gemini.api.key=YOUR_GEMINI_API_KEY

# Resilience4j Circuit Breaker
resilience4j.circuitbreaker.instances.geminiApi.sliding-window-size=5
resilience4j.circuitbreaker.instances.geminiApi.failure-rate-threshold=50
resilience4j.circuitbreaker.instances.geminiApi.wait-duration-in-open-state=10s
resilience4j.circuitbreaker.instances.geminiApi.permitted-numberOf-calls-in-half-open-state=3

# Resilience4j Retry
resilience4j.retry.instances.geminiApi.max-attempts=3
resilience4j.retry.instances.geminiApi.wait-duration=2s

# LiveKit Cloud
livekit.api.key=YOUR_LIVEKIT_API_KEY
livekit.api.secret=YOUR_LIVEKIT_API_SECRET
livekit.url=wss://your-project.livekit.cloud

# Internal Security for Python Worker
internal.python.secret=YOUR_INTERNAL_SECRET
